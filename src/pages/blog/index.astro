---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const categories = [...new Set(posts.map(p => p.data.category))];

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<BaseLayout title="All Stories" description="Browse all stories from The J88s Journal.">
  <div class="max-w-7xl mx-auto px-4 py-6">
    <div class="section-rule mb-2"><span class="section-title">Archive</span></div>
    <h1 class="headline-xl mb-8">All Stories</h1>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <div class="lg:col-span-8 space-y-6">
        {sortedPosts.map((post) => (
          <article class="grid grid-cols-1 md:grid-cols-3 gap-4 pb-6 border-b border-border-light">
            <div class="md:col-span-1">
              <a href={`/blog/${post.slug}/`}>
                <img src={post.data.heroImage} alt={post.data.title} class="w-full aspect-video object-cover" />
              </a>
            </div>
            <div class="md:col-span-2">
              <span class="section-title text-accent">{post.data.category}</span>
              <h2 class="headline-md mt-1 mb-2">
                <a href={`/blog/${post.slug}/`} class="hover:text-accent transition">{post.data.title}</a>
              </h2>
              <p class="font-body text-sm text-ink-light line-clamp-2">{post.data.description}</p>
              <span class="article-meta mt-2 block">{formatDate(post.data.pubDate)}</span>
            </div>
          </article>
        ))}
      </div>

      <aside class="lg:col-span-4">
        <div class="border border-border-paper p-5 bg-paper-dark">
          <div class="section-rule mb-4"><span class="section-title">Sections</span></div>
          <ul class="space-y-3">
            {categories.map(cat => (
              <li>
                <a href={`/tag/${cat.toLowerCase().replace(/\s+/g, '-')}/`} class="flex items-center justify-between font-body text-sm font-semibold hover:text-accent transition">
                  <span>{cat}</span>
                  <span class="text-ink-light font-normal">{posts.filter(p => p.data.category === cat).length}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
