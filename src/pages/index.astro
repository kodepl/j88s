---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = sortedPosts.find(p => p.data.featured) || sortedPosts[0];
const recentPosts = sortedPosts.filter(p => p !== featuredPost);

const categories = [...new Set(allPosts.map(p => p.data.category))];

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<BaseLayout title="The J88s Journal — Front Page" description="Trusted reporting and independent analysis from around the globe.">
  <div class="max-w-7xl mx-auto px-4 py-6">
    <!-- Featured Story (Above the Fold) -->
    {featuredPost && (
      <section class="border-b-2 border-border-paper pb-6 mb-6">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
          <!-- Main image -->
          <div class="lg:col-span-7">
            <a href={`/blog/${featuredPost.slug}/`}>
              <img src={featuredPost.data.heroImage} alt={featuredPost.data.title} class="w-full aspect-video object-cover" />
            </a>
          </div>
          <!-- Headline -->
          <div class="lg:col-span-5 flex flex-col justify-center">
            <span class="section-title text-accent mb-2">{featuredPost.data.category}</span>
            <h1 class="headline-xl mb-3">
              <a href={`/blog/${featuredPost.slug}/`} class="hover:text-accent transition">{featuredPost.data.title}</a>
            </h1>
            <p class="font-body text-ink-light text-lg leading-relaxed mb-3">{featuredPost.data.description}</p>
            <div class="byline">{formatDate(featuredPost.data.pubDate)}</div>
          </div>
        </div>
      </section>
    )}

    <!-- Secondary Stories -->
    <section class="mb-8">
      <div class="section-rule mb-4">
        <span class="section-title">Latest Stories</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {recentPosts.slice(0, 4).map((post) => (
          <article class="flex flex-col">
            <a href={`/blog/${post.slug}/`}>
              <img src={post.data.heroImage} alt={post.data.title} class="w-full aspect-video object-cover mb-3" />
            </a>
            <span class="section-title text-accent mb-1">{post.data.category}</span>
            <h2 class="headline-md mb-2">
              <a href={`/blog/${post.slug}/`} class="hover:text-accent transition">{post.data.title}</a>
            </h2>
            <p class="font-body text-sm text-ink-light line-clamp-3 mb-2">{post.data.description}</p>
            <span class="article-meta mt-auto">{formatDate(post.data.pubDate)}</span>
          </article>
        ))}
      </div>
    </section>

    <!-- Three Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Main Column -->
      <div class="lg:col-span-8">
        <div class="section-rule mb-4">
          <span class="section-title">More Coverage</span>
        </div>
        <div class="space-y-6">
          {recentPosts.slice(4, 12).map((post) => (
            <article class="grid grid-cols-1 md:grid-cols-3 gap-4 pb-6 border-b border-border-light">
              <div class="md:col-span-1">
                <a href={`/blog/${post.slug}/`}>
                  <img src={post.data.heroImage} alt={post.data.title} class="w-full aspect-video object-cover" />
                </a>
              </div>
              <div class="md:col-span-2">
                <span class="section-title text-accent">{post.data.category}</span>
                <h3 class="headline-md mt-1 mb-2">
                  <a href={`/blog/${post.slug}/`} class="hover:text-accent transition">{post.data.title}</a>
                </h3>
                <p class="font-body text-sm text-ink-light line-clamp-2">{post.data.description}</p>
                <span class="article-meta mt-2 block">{formatDate(post.data.pubDate)}</span>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 space-y-8">
        <!-- Categories -->
        <div class="border border-border-paper p-5 bg-paper-dark">
          <div class="section-rule mb-4">
            <span class="section-title">Sections</span>
          </div>
          <ul class="space-y-3">
            {categories.map(cat => (
              <li>
                <a href={`/tag/${cat.toLowerCase().replace(/\s+/g, '-')}/`} class="flex items-center justify-between font-body text-sm font-semibold hover:text-accent transition">
                  <span>{cat}</span>
                  <span class="text-ink-light font-normal">{allPosts.filter(p => p.data.category === cat).length}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Trending -->
        <div class="border border-border-paper p-5 bg-paper-dark">
          <div class="section-rule mb-4">
            <span class="section-title">Trending Topics</span>
          </div>
          <div class="flex flex-wrap gap-2">
            {['Technology', 'Science', 'Business', 'Health', 'Culture', 'Environment', 'Politics', 'Education'].map(tag => (
              <a href={`/tag/${tag.toLowerCase()}/`} class="tag-paper hover:bg-accent hover:text-white hover:border-accent transition">{tag}</a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
