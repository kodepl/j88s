---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="max-w-7xl mx-auto px-4 py-24 text-center">
    <div class="font-display text-7xl font-black text-accent mb-4">404</div>
    <div class="font-headline text-xl text-ink-light mb-4">Edition Not Found</div>
    <p class="font-body text-ink-light mb-8">This story has not been published yet.</p>
    <a href="/" class="inline-block bg-accent text-white font-body font-semibold px-6 py-3 hover:bg-accent-dark transition">Return to Front Page</a>
  </div>
</BaseLayout>
